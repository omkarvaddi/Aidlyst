{%- doc -%}
  This snippet is used to render a product card.
  It is used in the product block, featured product block, and the product card block.
  The product object is null or when placeholders are rendered.

  @param {object} product - The product object
  @param {object} children - The children of the product card
  @param {object} [block] - The block object
  @param {number} [product_card_gap] - The gap between the product card children (overrides block settings)
{%- enddoc -%}

{% assign block_settings = block.settings %}
{% capture product_sale_type_render %}{% render 'product-sale-type', product_resource: product %}{% endcapture %}
{% assign product_sale_type = product_sale_type_render | strip | default: 'affiliate' %}
{% capture primary_supplier_url_render %}{% render 'product-primary-supplier-url', product_resource: product %}{% endcapture %}
{% assign primary_supplier_url = primary_supplier_url_render | strip %}

{% style %}
  {% if request.visual_preview_mode %}
    product-card[data-product-transition] {
      width: 100%;
      min-width: 250px;
    }
  {% endif %}
{% endstyle %}

{% liquid
  assign has_quick_add = false
  if settings.quick_add and product.available and product_sale_type == 'direct'
    assign has_quick_add = true
  endif

  assign has_mobile_quick_add = false
  if has_quick_add and settings.mobile_quick_add
    assign has_mobile_quick_add = true
  endif

  assign product_card_id = 'product-card-link-' | append: block.id | append: '-' | append: product.id
  assign product_card_gap_value = product_card_gap | default: block_settings.product_card_gap

  # Logic to determine which variant URL to use (matching swatch selection logic)
  assign variant_to_link = product.selected_or_first_available_variant

  if settings.transition_to_main_product
    assign featured_image = variant_to_link.featured_image
    if featured_image == blank
      assign featured_image = product.featured_media.preview_image
    endif

    if featured_image != blank
      assign featured_media_url = featured_image | image_url: width: 500
    endif
  endif

  assign onboarding = false
  if product.id == empty or product == blank
    assign onboarding = true
  endif

  assign product_flow_badge = 'Partner Product'
  assign product_flow_cta = 'View Partner Product'
  assign product_flow_note = 'Disclosure applies'

  case product_sale_type
    when 'direct'
      assign product_flow_badge = 'Shop Direct'
      assign product_flow_cta = 'Shop Now'
      assign product_flow_note = 'Available for direct checkout'
    when 'provider_required'
      assign product_flow_badge = 'Provider Guidance Required'
      assign product_flow_cta = 'Request More Information'
      assign product_flow_note = 'Medical guidance may be required'
  endcase

  assign product_flow_href = product.url
  assign product_flow_external = false
  if product_sale_type != 'direct' and primary_supplier_url != blank
    assign product_flow_href = primary_supplier_url
    assign product_flow_external = true
  endif

  assign product_category = product.type | default: product.collections.first.title
  assign product_short_description = product.metafields.custom.short_description.value | default: product.metafields.custom.short_description | default: product.description | strip_html | strip | truncate: 118
%}

<product-card
  class="product-card size-style"
  style="{% render 'size-style', settings: block_settings %}"
  data-product-id="{{ product.id }}"
  data-aidlyst-sale-type="{{ product_sale_type }}"
  id="product-card-{{ block.id }}"
  {% if settings.transition_to_main_product %}
    data-product-transition="true"
    data-featured-media-url="{{ featured_media_url }}"
    on:click="/handleViewTransition"
  {% endif %}
  {{ block.shopify_attributes }}
  {% if onboarding %}
    data-placeholder="true"
  {% endif %}
>
  <a
    id="{{ product_card_id | md5 }}"
    {% unless onboarding %}
      href="{{ variant_to_link.url }}"
    {% endunless %}
    class="product-card__link"
    ref="productCardLink"
  >
    <span class="visually-hidden">
      {{ product.title }}
    </span>
  </a>
  <div
    class="
      product-card__content
      layout-panel-flex
      layout-panel-flex--column
      product-grid__card
      spacing-style
      border-style
      gap-style
      {% if block_settings.inherit_color_scheme == false %} color-{{ block_settings.color_scheme }}{% endif %}
    "
    style="
      {% render 'border-override', settings: block_settings %}
      {% render 'layout-panel-style', settings: block_settings %}
      {% render 'spacing-style', settings: block_settings %}
      {% render 'gap-style', value: product_card_gap_value, name: 'product-card-gap' %}
      --quick-add-display: {% if has_quick_add %}flex{% else %}none{% endif %};
      --quick-add-mobile-display: {% if has_mobile_quick_add %}flex{% else %}none{% endif %};
      --quick-add-mobile-opacity: {% if has_mobile_quick_add %}1{% else %}0{% endif %};
      {% if block_settings.padding-inline-start > 0 %}--zoom-out-padding-inline-start: min(var(--padding-xs), {{ block_settings.padding-inline-start | times: 0.7}}px);{% endif %}
      {% if block_settings.padding-inline-end > 0 %}--zoom-out-padding-inline-end: min(var(--padding-xs), {{ block_settings.padding-inline-end | times: 0.7}}px);{% endif %}
      {% if block_settings.padding-block-start > 0 %}--zoom-out-padding-block-start: min(var(--padding-xs), {{ block_settings.padding-block-start | times: 0.7}}px);{% endif %}
      {% if block_settings.padding-block-end > 0 %}--zoom-out-padding-block-end: min(var(--padding-xs), {{ block_settings.padding-block-end | times: 0.7}}px);{% endif %}
    "
  >
    {{ children }}
    {%- unless onboarding -%}
      <div class="aidlyst-card-flow aidlyst-card-flow--{{ product_sale_type }}">
        <div class="aidlyst-card-flow__meta">
          {%- if product_category != blank -%}
            <span class="aidlyst-card-flow__category">{{ product_category }}</span>
          {%- endif -%}
          <span class="aidlyst-card-flow__badge">{{ product_flow_badge }}</span>
        </div>

        {%- if product_short_description != blank -%}
          <p class="aidlyst-card-flow__description">{{ product_short_description }}</p>
        {%- endif -%}

        <a
          class="aidlyst-card-flow__cta"
          href="{{ product_flow_href }}"
          {% if product_flow_external %}target="_blank" rel="noopener noreferrer sponsored"{% endif %}
          data-aidlyst-link-type="{% if product_flow_external %}supplier{% else %}product-card{% endif %}"
          data-aidlyst-supplier="{% if product_flow_external %}Primary partner{% endif %}"
          data-aidlyst-product-id="{{ product.id }}"
          data-aidlyst-product-title="{{ product.title | escape }}"
          data-aidlyst-sale-type="{{ product_sale_type }}"
        >
          {{ product_flow_cta }}
        </a>

        <span class="aidlyst-card-flow__note">{{ product_flow_note }}</span>
      </div>
    {%- endunless -%}
  </div>
</product-card>

{% stylesheet %}
  .product-card__placeholder-image svg {
    height: 100%;
  }

  .product-card__content slideshow-component {
    --cursor: pointer;
  }

  @media screen and (max-width: 749px) {
    .product-card slideshow-arrows .slideshow-control {
      display: none;
    }
  }
{% endstylesheet %}
