# Aidlyst environment variable template
# Values here are examples or blank placeholders only. Do not commit real values.

# Public browser-safe config
NEXT_PUBLIC_SITE_URL=https://aidlyst.com
NEXT_PUBLIC_API_BASE_URL=https://api.aidlyst.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Server-only Supabase
DATABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Server-only Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# Internal Aidlyst controls
NODE_ENV=development
PORT=8791
AIDLYST_BIND_HOST=127.0.0.1
AIDLYST_INTERNAL_API_KEY=
AIDLYST_BACKEND_API_KEY=
AIDLYST_ENCRYPTION_KEY=
AIDLYST_AUDIT_DIR=
AIDLYST_CONTROL_DIR=
AIDLYST_DISABLE_DEV_AUTH=

# Compliance and supplier verification
FDA_GUDID_BASE_URL=https://accessgudid.nlm.nih.gov/api/v3
FDA_OPENAPI_BASE_URL=https://api.fda.gov
FDA_OPENAPI_KEY=
GOOGLE_MAPS_API_KEY=

# Transactional email and observability
RESEND_API_KEY=
EMAIL_FROM=hello@aidlyst.com
SENTRY_DSN=
AXIOM_TOKEN=

# Legacy or bridge-only Shopify values
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2026-04
